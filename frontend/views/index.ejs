<%- include('partials/header') %>

  <main>
    <section class="hero container">
      <h1 class="hero-title">
        Uzun URL'leri <span class="grad-text">saniyede</span> kısaltın
      </h1>
      <div class="hero-start" id="heroStart">
        <button
          type="button"
          id="startBtn"
          class="btn-primary hero-start-btn"
          data-authenticated="<%= (typeof currentUser !== 'undefined' && currentUser) ? '1' : '0' %>"
        >
          <span>Başla</span>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </button>
      </div>
      <form
        id="shortenForm"
        class="shorten-card hidden"
        autocomplete="off"
        novalidate
        data-user-email="<%= (typeof currentUser !== 'undefined' && currentUser) ? currentUser.email : '' %>"
      >
        <div class="field">
          <label for="long_url">Uzun URL</label>
          <div class="input-wrap">
            <svg class="input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
              <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
            </svg>
            <input type="url" id="long_url" name="url" required
                   placeholder="https://çok-uzun-bir-url.example.com/sayfa?param=deger" />
          </div>
        </div>

        <div class="field-row">
          <div class="field">
            <label for="custom_code">Özel kod (opsiyonel)</label>
            <div class="input-wrap">
              <span class="input-prefix">/</span>
              <input type="text" id="custom_code" name="custom_code" maxlength="32"
                     pattern="[A-Za-z0-9_-]{3,32}"
                     placeholder="örnek-kod" />
            </div>
            <div id="customCodeError" class="field-error hidden" aria-live="polite"></div>
          </div>
          <div class="field">
            <label for="expires_in_days">Sona erme</label>
            <select id="expires_in_days" name="expires_in_days">
              <option value="">Sonsuz</option>
              <option value="1">1 gün</option>
              <option value="7">7 gün</option>
              <option value="30">30 gün</option>
              <option value="365">1 yıl</option>
            </select>
          </div>
        </div>

        <button type="submit" class="btn-primary">
          <span class="btn-label">Kısalt</span>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </button>
      </form>

      <div id="result" class="result-card hidden">
        <div class="result-head">
          <span class="result-pill">Hazır</span>
          <span class="result-time" id="resultTime"></span>
        </div>
        <div class="result-body">
          <div class="result-grid">
            <div class="result-info">
              <div class="result-url-row">
                <a id="resultUrl" class="result-url" href="#" target="_blank" rel="noopener"></a>
                <button id="copyBtn" class="btn-ghost" title="Kopyala">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                    <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                  </svg>
                </button>
              </div>
              <div class="result-long" id="resultLong"></div>
              <div class="result-actions">
                <a id="resultStatsLink" class="btn-secondary" href="#">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="18" y1="20" x2="18" y2="10"></line>
                    <line x1="12" y1="20" x2="12" y2="4"></line>
                    <line x1="6" y1="20" x2="6" y2="14"></line>
                  </svg>
                  İstatistikleri gör
                </a>
                <a id="qrDownload" class="btn-tertiary" href="#" download>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                    <polyline points="7 10 12 15 17 10"></polyline>
                    <line x1="12" y1="15" x2="12" y2="3"></line>
                  </svg>
                  QR indir
                </a>
                <button id="newBtn" class="btn-tertiary">Yeni kısalt</button>
              </div>
            </div>
            <div class="result-qr">
              <div class="qr-frame">
                <img id="qrImage" alt="QR kod" />
              </div>
              <span class="qr-caption">Tarat ve aç</span>
            </div>
          </div>
        </div>
      </div>

    </section>

  </main>

  <script src="/static/js/main.js?v=20260508-3"></script>
  <script src="/static/js/home.js?v=20260510-3"></script>

<%- include('partials/footer') %>
