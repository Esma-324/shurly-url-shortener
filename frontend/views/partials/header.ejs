<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Shurly - Yüksek performanslı, Rust ile yazılmış URL kısaltma servisi" />
  <title><%= title %></title>
  <script>
    (function () {
      try {
        var t = localStorage.getItem('shurly-theme');
        if (!t) {
          t = (window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches) ? 'light' : 'dark';
        }
        document.documentElement.setAttribute('data-theme', t);
      } catch (e) {}
    })();
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdn-uicons.flaticon.com/uicons-regular-rounded/css/uicons-regular-rounded.css" />
  <link rel="stylesheet" href="/static/css/style.css?v=20260510-01" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='80' font-size='80'>&#128279;</text></svg>" />
</head>
<% var isAuthPage = (typeof page !== 'undefined' && page === 'auth'); %>
<% var isAdminUser = (typeof currentUser !== 'undefined' && currentUser && currentUser.role === 'admin'); %>
<body class="<%= isAuthPage ? 'body-auth' : '' %>">
  <script>
    window.__SHURLY_PUBLIC_BACKEND__ = <%- JSON.stringify(typeof publicBackendUrl !== 'undefined' ? publicBackendUrl : '') %>;
  </script>
  <div class="bg-effects">
    <div class="bg-blob bg-blob-1"></div>
    <div class="bg-blob bg-blob-2"></div>
    <div class="bg-blob bg-blob-3"></div>
    <div class="bg-grid"></div>
  </div>

  <header class="navbar">
    <div class="container nav-content">
      <a href="<%= isAdminUser ? '/admin' : '/' %>" class="brand">
        <span class="brand-mark">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
            <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
          </svg>
        </span>
        <span class="brand-name">Shurly</span>
      </a>
      <nav class="nav-links">
        <% if (isAdminUser) { %>
          <a href="/admin" class="<%= page === 'admin' ? 'active' : '' %>">Admin</a>
        <% } else { %>
          <a href="/" class="<%= page === 'home' ? 'active' : '' %>">Anasayfa</a>
          <% if (typeof currentUser !== 'undefined' && currentUser) { %>
            <a href="/stats" class="<%= page === 'stats' ? 'active' : '' %>">İstatistik</a>
            <a href="/history" class="<%= page === 'history' ? 'active' : '' %>">Geçmiş</a>
          <% } %>
        <% } %>
      </nav>
      <div class="nav-auth">
        <button type="button" id="themeToggle" class="theme-toggle" title="Tema değiştir" aria-label="Tema değiştir">
          <svg class="ico-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="4"></circle>
            <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
          </svg>
          <svg class="ico-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
          </svg>
        </button>
        <% if (typeof currentUser !== 'undefined' && currentUser) { %>
          <span class="user-pill"><%= currentUser.email %> &middot; <%= currentUser.role %></span>
          <form method="post" action="/auth/logout">
            <button type="submit" class="btn-auth">Çıkış</button>
          </form>
        <% } else { %>
          <a href="/login" class="btn-auth <%= page === 'auth' ? 'active' : '' %>">Login</a>
        <% } %>
      </div>
    </div>
  </header>
