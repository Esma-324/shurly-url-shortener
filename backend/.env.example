HOST=0.0.0.0
PORT=8080
BASE_URL=http://localhost:8080
DATABASE_URL=postgres://postgres:postgres@localhost:5432/urlshortener
REDIS_URL=redis://127.0.0.1:6379
# Yerelde Redis yoksa baglanti hatasinda uyari verip cache'siz devam et (docker-compose ile Redis kullanirken kaldirin)
REDIS_OPTIONAL=true
RATE_LIMIT_PER_MINUTE=60
SHORT_CODE_LENGTH=7
CACHE_TTL_SECONDS=3600
RUST_LOG=info,sqlx=warn,actix_web=info
